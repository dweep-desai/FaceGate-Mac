# Project specific exclusions
PURPOSE.md
purpose.md
*.xcodeproj/
*.xcworkspace/
FaceGate.xcodeproj/

# macOS / OS X
.DS_Store
.AppleDouble
.LSOverride

# Icon must end with two \r
Icon

# Thumbnails
._*

# Files that might be created by Xcode
*.mode1v3
*.mode2v3
*.perspectivev3
!default.perspectivev3
xcuserdata/
DerivedData/
.swiftpm/
*.xcworkspace
build/

# Python / Scripts environment if any
__pycache__/
*.pyc
*.pyo
*.pyd
.env
venv/
.venv/
env/

# Sparkle private key — never commit
releases/sparkle_private.pem
releases/sparkle_private_raw.key

# Built DMG — too large for git, distribute via GitHub Releases
*.dmg

# Certificates and Provisioning Profiles
*.mobileprovision
*.provisionprofile
*.p12
*.cer
*.p8
*.cert

# Application Database, Embeddings, and User Data (Do not commit PII or Face Data)
*.sqlite
*.sqlite3
*.db
*.realm


# macOS / Xcode Specific Overrides
*.moved-aside
.Trashes
FaceGate-1.0.0.dmg
